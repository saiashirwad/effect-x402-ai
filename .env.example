# A 12/24-word seed phrase for a throwaway wallet funded with a little USDC on Base.
# This wallet pays for inference — no Venice API key needed.
SEED_PHRASE="word1 word2 ... word12"

# Elfa chat speed mode: "fast" (5 credits / $0.045) or "expert" (18 credits / $0.162).
# Defaults to "expert" if omitted.
ELFA_SPEED="expert"
